#!/bin/sh

commit_msg_file="$1"
commit_msg="$(cat "$commit_msg_file")"

pattern='^(feat|fix|docs|ci|chore|test|perf|refactor|build|style|revert)(\([a-z0-9._/-]+\))?(!)?: .+'
merge_pattern='^Merge .+'
revert_pattern='^Revert ".+"'

if printf '%s' "$commit_msg" | grep -Eq "$merge_pattern"; then
  exit 0
fi

if printf '%s' "$commit_msg" | grep -Eq "$revert_pattern"; then
  exit 0
fi

if ! printf '%s' "$commit_msg" | grep -Eq "$pattern"; then
  echo "✖ Commit message must follow Conventional Commits."
  echo "  Expected: <type>(<scope>): <description>"
  echo "  Example: feat(auth): add JWT middleware"
  exit 1
fi