{
  "name": "ephops-monorepo",
  "version": "0.0.1",
  "description": "EphOps - AI-Driven Ephemeral Environment & FinOps Platform",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.17",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:api": "pnpm -C packages/api run start:dev",
    "dev:web": "pnpm -C packages/web run dev",
    "build": "pnpm -r run build",
    "build:api": "pnpm -C packages/api run build",
    "build:web": "pnpm -C packages/web run build",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json}\"",
    "type-check": "pnpm -r run type-check",
    "test": "pnpm -r run test",
    "test:api": "pnpm -C packages/api run test",
    "test:e2e": "pnpm -C packages/api run test:e2e"
  },
  "devDependencies": {
    "prettier": "^3.4.2"
  }
}
