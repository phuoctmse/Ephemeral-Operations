# .dockerignore — EphOps Monorepo

# Version control
.git/
.github/
.gitignore

# All node_modules (installed inside container)
node_modules/
packages/*/node_modules/

# Build outputs (built inside container)
dist/
packages/*/dist/
packages/web/dist/

# Environment files (injected at runtime)
.env
.env.*
!.env.example

# Dev tooling
.vscode/
.idea/
.husky/
.agent/
.agents/
.kiro/

# Logs & coverage
*.log
coverage/
packages/*/coverage/
.eslintcache

# OS
.DS_Store
Thumbs.db

# Docs
*.md
DESIGN.md
PRODUCT.md
project-spec.md

# Docker files themselves
docker-compose.yml
compose.yml
Dockerfile
.dockerignore

# Local data volumes
data/

# Test files must remain in the build context for Docker test targets
